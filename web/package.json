{
  "name": "zmk-mouse-gesture-rpc-web",
  "private": true,
  "version": "0.1.0",
  "type": "module",
  "scripts": {
    "dev": "vite",
    "build": "tsc -b && vite build",
    "preview": "vite preview",
    "lint": "eslint . --ext .ts,.tsx",
    "proto:gen": "protoc --plugin=./node_modules/.bin/protoc-gen-ts_proto --ts_proto_out=src/proto --ts_proto_opt=esModuleInterop=true,forceLong=number --proto_path=../proto ../proto/zmk/mouse_gesture/custom.proto"
  },
  "dependencies": {
    "@cormoran/zmk-studio-react-hook": "^0.3.0",
    "@zmkfirmware/zmk-studio-ts-client": "^0.3.0",
    "react": "^19.0.0",
    "react-dom": "^19.0.0"
  },
  "devDependencies": {
    "@types/react": "^19.0.0",
    "@types/react-dom": "^19.0.0",
    "@vitejs/plugin-react": "^4.3.0",
    "ts-proto": "^2.6.0",
    "typescript": "^5.6.0",
    "vite": "^6.0.0"
  }
}
